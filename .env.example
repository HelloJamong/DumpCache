# DC Inside Gallery Configuration

# 갤러리 URL (전체 URL 입력 시 자동으로 ID와 타입 파싱)
# 예시:
# - 일반: https://gall.dcinside.com/board/lists/?id=programming
# - 마이너: https://gall.dcinside.com/mgallery/board/lists/?id=baseball_new11
# - 미니: https://gall.dcinside.com/mini/board/lists/?id=boobs
GALLERY_URL=https://gall.dcinside.com/board/lists/?id=programming

# 수집 간격 (초 단위, 60 = 1분)
CRAWL_INTERVAL=60

# 이미지 저장 경로 (컨테이너 내부 경로, 변경 비추천)
IMAGE_SAVE_PATH=/app/data/images

# 메타데이터 DB 경로 (컨테이너 내부 경로, 변경 비추천)
METADATA_DB_PATH=/app/data/metadata.db

# 한 번에 처리할 게시글 수 (공지 제외)
MAX_POSTS_PER_CYCLE=10

# 디버그 모드 (True/False)
DEBUG=False
